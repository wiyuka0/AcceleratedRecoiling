{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/${presetName}",
      "environment": {
        "PATH": "$env{AR_TOOLCHAIN}/tools/clang/bin;$env{AR_TOOLCHAIN}/tools/cmake/bin;$env{AR_TOOLCHAIN}/tools/ninja/bin;$penv{PATH}",
        "AR_LLVM": "$env{AR_TOOLCHAIN}/tools/clang/bin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",

        "CMAKE_MAKE_PROGRAM": "$env{AR_TOOLCHAIN}/tools/ninja/bin/ninja.exe",
        "CMAKE_C_COMPILER": "$env{AR_LLVM}/clang.exe",
        "CMAKE_CXX_COMPILER": "$env{AR_LLVM}/clang++.exe",
        "CMAKE_ASM_COMPILER": "$env{AR_LLVM}/clang.exe",

        "CMAKE_C_FLAGS": "$env{AR_COMPILER_FLAG}",
        "CMAKE_CXX_FLAGS": "$env{AR_COMPILER_FLAG}",
        "CMAKE_ASM_FLAGS": "$env{AR_COMPILER_FLAG}",

        "CMAKE_LINKER_TYPE": "LLD",

        "CMAKE_RC_COMPILER": "$env{AR_LLVM}/llvm-rc.exe",
        "CMAKE_MT": "$env{AR_LLVM}/llvm-mt.exe",
        "CMAKE_NM": "$env{AR_LLVM}/llvm-nm.exe",
        "CMAKE_ADDR2LINEFILEPATH": "$env{AR_LLVM}/llvm-addr2line.exe",
        "CMAKE_C_COMPILER_RANLIBFILEPATH": "$env{AR_LLVM}/llvm-ranlib.exe",
        "CMAKE_C_COMPILER_ARFILEPATH": "$env{AR_LLVM}/llvm-ar.exe",
        "CMAKE_CXX_COMPILER_RANLIBFILEPATH": "$env{AR_LLVM}/llvm-ranlib.exe",
        "CMAKE_CXX_COMPILER_ARFILEPATH": "$env{AR_LLVM}/llvm-ar.exe",
        "CMAKE_ARFILEPATH": "$env{AR_LLVM}/llvm-ar.exe",
        "CMAKE_OBJCOPYFILEPATH": "$env{AR_LLVM}/llvm-objcopy.exe",
        "CMAKE_OBJDUMPFILEPATH": "$env{AR_LLVM}/llvm-objdump.exe",
        "CMAKE_READELFFILEPATH": "$env{AR_LLVM}/llvm-readelf.exe",
        "CMAKE_STRIPFILEPATH": "$env{AR_LLVM}/llvm-strip.exe",
        "CMAKE_TAPIFILEPATH": "$env{AR_LLVM}/llvm-readtapi.exe",

        "AR_TOOLCHAIN": "1",
        "AR_ENABLE_JNI": "1"
      }
    },
    {
      "name": "win-x64",
      "inherits": ["base"],
      "environment": {
        "AR_SYSROOT": "$env{AR_TOOLCHAIN}/sysroot/x86_64-windows-msvc",
        "AR_COMPILER_FLAG": "-fmsc-version=1944 /winsysroot \"$env{AR_SYSROOT}\"",
        "AR_LINKER_FLAG": "/machine:x64 \"/winsysroot:$env{AR_SYSROOT}\" /MANIFEST:NO"
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64",

        "CMAKE_C_COMPILER": "$env{AR_LLVM}/clang-cl.exe",
        "CMAKE_CXX_COMPILER": "$env{AR_LLVM}/clang-cl.exe",
        "CMAKE_ASM_COMPILER": "$env{AR_LLVM}/clang-cl.exe",

        "CMAKE_SHARED_LINKER_FLAGS": "$env{AR_LINKER_FLAG}",
        "CMAKE_MODULE_LINKER_FLAGS": "$env{AR_LINKER_FLAG}",
        "CMAKE_EXE_LINKER_FLAGS": "$env{AR_LINKER_FLAG}",

        "CMAKE_AR": "$env{AR_LLVM}/llvm-lib.exe",

        "AR_SYSTEM": "WINDOWS",
        "AR_ARCH": "X64",
        "AR_WINDOWS": "1",
        "AR_X64": "1"
      }
    },
    {
      "name": "win-x64-debug",
      "inherits": ["win-x64"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unix-base",
      "hidden": true,
      "inherits": ["base"],
      "cacheVariables": {
        "CMAKE_AR": "$env{AR_LLVM}/llvm-ar.exe",
        "CMAKE_RANLIB": "$env{AR_LLVM}/llvm-ranlib.exe"
      }
    },
    {
      "name": "linux-x64",
      "inherits": ["unix-base"],
      "environment": {
        "AR_SYSROOT": "$env{AR_TOOLCHAIN}/sysroot/x86_64-linux-gnu",
        "AR_COMPILER_FLAG": "-target x86_64-linux-gnu --sysroot \"$env{AR_SYSROOT}\""
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64",
        "CMAKE_CXX_FLAGS": "$env{AR_COMPILER_FLAG} -stdlib=libstdc++",

        "AR_SYSTEM": "LINUX",
        "AR_ARCH": "X64",
        "AR_LINUX": "1",
        "AR_X64": "1"
      }
    },
    {
      "name": "android-arm64",
      "inherits": ["unix-base"],
      "environment": {
        "AR_SYSROOT": "$env{AR_TOOLCHAIN}/sysroot/aarch64-linux-android",
        "AR_COMPILER_FLAG": "-DANDROID --target=aarch64-linux-android28 -no-canonical-prefixes -fPIC --sysroot \"$env{AR_SYSROOT}\""
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64",
        "CMAKE_CXX_FLAGS": "$env{AR_COMPILER_FLAG} -stdlib=libc++",

        "AR_SYSTEM": "ANDROID",
        "AR_ARCH": "AARCH64",
        "AR_ANDROID": "1",
        "AR_AARCH64": "1"
      }
    },
    {
      "name": "macos-arm64",
      "inherits": ["unix-base"],
      "environment": {
        "AR_SYSROOT": "$env{AR_TOOLCHAIN}/sysroot/aarch64+x86_64-apple-macos",
        "AR_COMPILER_FLAG": "--target=arm64-apple-macosx14.5 -fPIC --sysroot \"$env{AR_SYSROOT}\""
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_SYSTEM_PROCESSOR": "arm64",
        "CMAKE_CXX_FLAGS": "$env{AR_COMPILER_FLAG} -stdlib=libc++",

        "AR_SYSTEM": "DARWIN",
        "AR_ARCH": "AARCH64",
        "AR_DARWIN": "1",
        "AR_AARCH64": "1"
      }
    },
    {
      "name": "macos-x64",
      "inherits": ["unix-base"],
      "environment": {
        "AR_SYSROOT": "$env{AR_TOOLCHAIN}/sysroot/aarch64+x86_64-apple-macos",
        "AR_COMPILER_FLAG": "--target=x86_64-apple-macosx14.5 -fPIC --sysroot \"$env{AR_SYSROOT}\""
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64",
        "CMAKE_CXX_FLAGS": "$env{AR_COMPILER_FLAG} -stdlib=libc++",

        "AR_SYSTEM": "DARWIN",
        "AR_ARCH": "X64",
        "AR_DARWIN": "1",
        "AR_X64": "1"
      }
    }
  ]
}